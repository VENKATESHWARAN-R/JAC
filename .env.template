# JAC environment template — illustrative values only.
# Synced with src/jac/data/providers.yaml (provider catalog). Not loaded unless you copy to .env.

# Pydantic AI Gateway
PYDANTIC_AI_GATEWAY_API_KEY=xxxx

# Model override (normally set by profile activation as JAC_MODEL)
JAC_MODEL=ollama:gemma4:31b-cloud

# Ollama (local) — optional when using an ollama:* model
OLLAMA_BASE_URL=http://localhost:11434/v1

# Provider API keys (see providers.yaml for the full list)
ANTHROPIC_API_KEY=xxxx
OPENAI_API_KEY=xxxx
GEMINI_API_KEY=xxxx
MISTRAL_API_KEY=xxxx
OPENROUTER_API_KEY=xxxx
GROQ_API_KEY=xxxx
COHERE_API_KEY=xxxx

# Optional: upgrades `web_search` from DuckDuckGo to Tavily when set.
# Sign up at https://app.tavily.com/home for a key.
TAVILY_API_KEY=xxxx
